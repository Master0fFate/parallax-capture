<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ─── TOOL ICONS ─── -->
    
    <!-- Pen Icon -->
    <Canvas x:Key="IconPen" Width="16" Height="16">
        <Path Data="M2.5,13 L5.5,10 L10.5,5 L13,2.5 C13.4,2.1 13.4,1.5 13,1.1 L12.9,1 C12.5,0.6 11.9,0.6 11.5,1 L9,3.5 L4,8.5 L1,12.5 Z"
              Fill="White" Stretch="Uniform" />
        <Line X1="1" Y1="12.5" X2="2.5" Y2="14" Stroke="White" StrokeThickness="1" />
    </Canvas>

    <!-- Arrow Icon -->
    <Canvas x:Key="IconArrow" Width="16" Height="16">
        <Line X1="2" Y1="14" X2="14" Y2="2" Stroke="White" StrokeThickness="1.5" StrokeEndLineCap="Round" />
        <!-- Proper arrowhead: triangle at (14,2) pointing up-right -->
        <Polygon Points="14,2 8,4 10,8" Fill="White" />
    </Canvas>

    <!-- Rectangle Icon -->
    <Canvas x:Key="IconRectangle" Width="16" Height="16">
        <Rectangle Width="12" Height="10" Canvas.Left="2" Canvas.Top="3"
                   Stroke="White" StrokeThickness="1.5" Fill="Transparent" />
    </Canvas>

    <!-- Ellipse Icon -->
    <Canvas x:Key="IconEllipse" Width="16" Height="16">
        <Ellipse Width="12" Height="10" Canvas.Left="2" Canvas.Top="3"
                 Stroke="White" StrokeThickness="1.5" Fill="Transparent" />
    </Canvas>

    <!-- Text Icon -->
    <Canvas x:Key="IconText" Width="16" Height="16">
        <TextBlock Text="T" FontSize="14" FontWeight="Bold" Foreground="White"
                   Canvas.Left="2" Canvas.Top="1" FontFamily="Segoe UI" />
        <Line X1="2" Y1="14" X2="14" Y2="14" Stroke="White" StrokeThickness="1" />
    </Canvas>

    <!-- Highlighter Icon -->
    <Canvas x:Key="IconHighlighter" Width="16" Height="16">
        <Rectangle Width="14" Height="4" Canvas.Left="1" Canvas.Top="6"
                   Fill="#66FFFFFF" Stroke="White" StrokeThickness="0.5" />
        <Rectangle Width="14" Height="2" Canvas.Left="1" Canvas.Top="8"
                   Fill="#33FFFFFF" />
        <Line X1="4" Y1="3" X2="4" Y2="13" Stroke="White" StrokeThickness="0.5" />
        <Line X1="12" Y1="3" X2="12" Y2="13" Stroke="White" StrokeThickness="0.5" />
    </Canvas>

    <!-- Blur Icon -->
    <Canvas x:Key="IconBlur" Width="16" Height="16">
        <Ellipse Width="10" Height="10" Canvas.Left="3" Canvas.Top="3"
                 Stroke="White" StrokeThickness="1" Fill="Transparent" />
        <Ellipse Width="8" Height="8" Canvas.Left="4" Canvas.Top="4"
                 Stroke="White" StrokeThickness="0.5" Fill="Transparent" Opacity="0.5" />
        <Ellipse Width="6" Height="6" Canvas.Left="5" Canvas.Top="5"
                 Stroke="White" StrokeThickness="0.3" Fill="Transparent" Opacity="0.3" />
    </Canvas>

    <!-- Color Picker Icon -->
    <Canvas x:Key="IconColorPicker" Width="16" Height="16">
        <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1"
                 Stroke="White" StrokeThickness="1" Fill="Transparent" />
        <Rectangle Width="6" Height="6" Canvas.Left="5" Canvas.Top="5"
                   Fill="White" />
    </Canvas>

    <!-- Undo Icon -->
    <Canvas x:Key="IconUndo" Width="16" Height="16">
        <Path Data="M8,2 C4.7,2 2,4.7 2,8 L0.5,6.5 L0,7 L3,10 L6,7 L5.5,6.5 L4,8 C4,5.2 6.2,3 9,3 C11.8,3 14,5.2 14,8 C14,10.8 11.8,13 9,13 L8,13 L8,14 L9,14 C12.3,14 15,11.3 15,8 C15,4.7 12.3,2 9,2 Z"
              Fill="White" Stretch="Uniform" />
    </Canvas>

    <!-- Clear / Trash Icon -->
    <Canvas x:Key="IconClear" Width="16" Height="16">
        <Path Data="M4,14 L5.5,14 L5.5,6 L4,6 Z M7,14 L8.5,14 L8.5,6 L7,6 Z M10,14 L11.5,14 L11.5,6 L10,6 Z"
              Fill="White" Stretch="Uniform" />
        <Polygon Points="2,4 5,4 6,2 10,2 11,4 14,4 14,5 2,5" Fill="White" />
    </Canvas>

    <!-- ─── TOOL BUTTON STYLE ─── -->
    <Style x:Key="ToolButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="2">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FF4A4A6E" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FF007ACC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── ACTION BUTTON STYLE ─── -->
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#FF2A2A4E" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#555577" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="MinWidth" Value="60" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,4,0" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FF3A3A6E" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FF007ACC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─── SLIDER STYLE ─── -->
    <Style x:Key="CustomSliderStyle" TargetType="Slider">
        <Setter Property="Minimum" Value="1" />
        <Setter Property="Maximum" Value="20" />
        <Setter Property="Value" Value="2" />
        <Setter Property="Width" Value="80" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

</ResourceDictionary>
