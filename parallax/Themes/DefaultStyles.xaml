<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fixed product color system. -->
    <SolidColorBrush x:Key="ProductWindowBrush" Color="#FF111318" />
    <SolidColorBrush x:Key="ProductChromeBrush" Color="#FF1B1B20" />
    <SolidColorBrush x:Key="ProductSurfaceBrush" Color="#FF211F26" />
    <SolidColorBrush x:Key="ProductSurfaceRaisedBrush" Color="#FF2B2930" />
    <SolidColorBrush x:Key="ProductSurfaceHoverBrush" Color="#FF36333B" />
    <SolidColorBrush x:Key="ProductSurfacePressedBrush" Color="#FF141218" />
    <SolidColorBrush x:Key="ProductButtonBrush" Color="#FF2F2D35" />
    <SolidColorBrush x:Key="ProductButtonHoverBrush" Color="#FF3B3842" />
    <SolidColorBrush x:Key="ProductButtonPressedBrush" Color="#FF25232B" />
    <SolidColorBrush x:Key="ProductInputBrush" Color="#FF17151B" />
    <SolidColorBrush x:Key="ProductInputHoverBrush" Color="#FF211F26" />
    <SolidColorBrush x:Key="ProductBorderBrush" Color="#FF49454F" />
    <SolidColorBrush x:Key="ProductBorderStrongBrush" Color="#FF938F99" />
    <SolidColorBrush x:Key="ProductSeparatorBrush" Color="#FF322F37" />
    <SolidColorBrush x:Key="ProductTextBrush" Color="#FFE6E1E5" />
    <SolidColorBrush x:Key="ProductTextMutedBrush" Color="#FFCAC4D0" />
    <SolidColorBrush x:Key="ProductTextSubtleBrush" Color="#FF938F99" />
    <SolidColorBrush x:Key="ProductAccentBrush" Color="#FFD0BCFF" />
    <SolidColorBrush x:Key="ProductAccentHoverBrush" Color="#FFE9DDFF" />
    <SolidColorBrush x:Key="ProductAccentPressedBrush" Color="#FFB69DF8" />
    <SolidColorBrush x:Key="ProductAccentTextBrush" Color="#FF381E72" />
    <SolidColorBrush x:Key="ProductFocusBrush" Color="#FFD0BCFF" />
    <SolidColorBrush x:Key="ProductDangerBrush" Color="#FFF2B8B5" />
    <SolidColorBrush x:Key="ProductDangerHoverBrush" Color="#FFFFDAD6" />
    <SolidColorBrush x:Key="ProductDangerPressedBrush" Color="#FFEFB8C8" />
    <SolidColorBrush x:Key="ProductWarningBrush" Color="#FFFFDDB3" />
    <SolidColorBrush x:Key="ProductWarningSurfaceBrush" Color="#FF332716" />
    <SolidColorBrush x:Key="ProductSuccessBrush" Color="#FF8CDFAF" />
    <SolidColorBrush x:Key="ProductDisabledBrush" Color="#FF24232A" />
    <SolidColorBrush x:Key="ProductDisabledTextBrush" Color="#FF79747E" />
    <SolidColorBrush x:Key="ProductOverlayBrush" Color="#CC000000" />

    <Style x:Key="ProductFocusVisualStyle" TargetType="Control">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="2"
                               Stroke="{DynamicResource ProductFocusBrush}"
                               StrokeThickness="1"
                               StrokeDashArray="1 2"
                               SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductWindowStyle" TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource ProductWindowBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style x:Key="ProductHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="ProductSectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="ProductSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ProductTextMutedBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="ProductBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="ProductCaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource ProductTextSubtleBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="ProductSectionBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource ProductSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <!-- ─── TOOL ICONS ─── -->
    
    <!-- Pen Icon -->
    <Canvas x:Key="IconPen" Width="16" Height="16">
        <Path Data="M2.5,13 L5.5,10 L10.5,5 L13,2.5 C13.4,2.1 13.4,1.5 13,1.1 L12.9,1 C12.5,0.6 11.9,0.6 11.5,1 L9,3.5 L4,8.5 L1,12.5 Z"
              Fill="{DynamicResource ProductTextBrush}" Stretch="Uniform" />
        <Line X1="1" Y1="12.5" X2="2.5" Y2="14" Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1" />
    </Canvas>

    <!-- Arrow Icon -->
    <Canvas x:Key="IconArrow" Width="16" Height="16">
        <Line X1="2" Y1="14" X2="14" Y2="2" Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.5" StrokeEndLineCap="Round" />
        <!-- Proper arrowhead: triangle at (14,2) pointing up-right -->
        <Polygon Points="14,2 8,4 10,8" Fill="{DynamicResource ProductTextBrush}" />
    </Canvas>

    <!-- Rectangle Icon -->
    <Canvas x:Key="IconRectangle" Width="16" Height="16">
        <Rectangle Width="12" Height="10" Canvas.Left="2" Canvas.Top="3"
                   Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.5" Fill="Transparent" />
    </Canvas>

    <!-- Ellipse Icon -->
    <Canvas x:Key="IconEllipse" Width="16" Height="16">
        <Ellipse Width="12" Height="10" Canvas.Left="2" Canvas.Top="3"
                 Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.5" Fill="Transparent" />
    </Canvas>

    <!-- Text Icon -->
    <Canvas x:Key="IconText" Width="16" Height="16">
        <TextBlock Text="T" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource ProductTextBrush}"
                   Canvas.Left="2" Canvas.Top="1" FontFamily="Segoe UI" />
        <Line X1="2" Y1="14" X2="14" Y2="14" Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1" />
    </Canvas>

    <!-- Highlighter Icon -->
    <Canvas x:Key="IconHighlighter" Width="16" Height="16">
        <Rectangle Width="14" Height="4" Canvas.Left="1" Canvas.Top="6"
                   Fill="{DynamicResource ProductAccentBrush}" Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="0.5" Opacity="0.75" />
        <Rectangle Width="14" Height="2" Canvas.Left="1" Canvas.Top="8"
                   Fill="{DynamicResource ProductAccentPressedBrush}" Opacity="0.6" />
        <Line X1="4" Y1="3" X2="4" Y2="13" Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="0.5" />
        <Line X1="12" Y1="3" X2="12" Y2="13" Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="0.5" />
    </Canvas>

    <!-- Blur Icon -->
    <Canvas x:Key="IconBlur" Width="16" Height="16">
        <Ellipse Width="10" Height="10" Canvas.Left="3" Canvas.Top="3"
                 Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1" Fill="Transparent" />
        <Ellipse Width="8" Height="8" Canvas.Left="4" Canvas.Top="4"
                 Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="0.5" Fill="Transparent" Opacity="0.5" />
        <Ellipse Width="6" Height="6" Canvas.Left="5" Canvas.Top="5"
                 Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="0.3" Fill="Transparent" Opacity="0.3" />
    </Canvas>

    <!-- Color Picker Icon -->
    <Canvas x:Key="IconColorPicker" Width="16" Height="16">
        <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1"
                 Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1" Fill="Transparent" />
        <Rectangle Width="6" Height="6" Canvas.Left="5" Canvas.Top="5"
                   Fill="{DynamicResource ProductTextBrush}" />
    </Canvas>

    <!-- Undo Icon -->
    <Canvas x:Key="IconUndo" Width="16" Height="16">
        <Path Data="M8,2 C4.7,2 2,4.7 2,8 L0.5,6.5 L0,7 L3,10 L6,7 L5.5,6.5 L4,8 C4,5.2 6.2,3 9,3 C11.8,3 14,5.2 14,8 C14,10.8 11.8,13 9,13 L8,13 L8,14 L9,14 C12.3,14 15,11.3 15,8 C15,4.7 12.3,2 9,2 Z"
              Fill="{DynamicResource ProductTextBrush}" Stretch="Uniform" />
    </Canvas>

    <!-- Clear / Trash Icon -->
    <Canvas x:Key="IconClear" Width="16" Height="16">
        <Path Data="M4,14 L5.5,14 L5.5,6 L4,6 Z M7,14 L8.5,14 L8.5,6 L7,6 Z M10,14 L11.5,14 L11.5,6 L10,6 Z"
              Fill="{DynamicResource ProductTextBrush}" Stretch="Uniform" />
        <Polygon Points="2,4 5,4 6,2 10,2 11,4 14,4 14,5 2,5" Fill="{DynamicResource ProductTextBrush}" />
    </Canvas>

    <Style x:Key="ProductButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ProductButtonBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDefaulted" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ProductAccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ProductButtonHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderStrongBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ProductButtonPressedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductAccentBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ProductDisabledBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductDisabledBrush}" />
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ProductPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource ProductAccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductAccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProductAccentTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ProductAccentHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductAccentHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ProductAccentPressedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductAccentPressedBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ProductDisabledBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductDisabledBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ProductDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource ProductDangerBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductDangerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProductAccentTextBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ProductDangerHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductDangerHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ProductDangerPressedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductDangerPressedBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ProductDisabledBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ProductDisabledBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ProductTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource ProductInputBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource ProductAccentBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      SnapsToDevicePixels="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ProductInputHoverBrush}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ProductBorderStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource ProductDisabledBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="itemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource ProductSurfaceHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource ProductAccentPressedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ProductAccentTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource ProductInputBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="10,6,34,6" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ProductComboBoxItemStyle}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="rootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <ToggleButton x:Name="toggleButton"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              ClickMode="Press"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="contentSite"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  IsHitTestVisible="False"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                                <TextBox x:Name="PART_EditableTextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Margin="{TemplateBinding Padding}"
                                         Style="{x:Null}"
                                         Visibility="Hidden" />
                                <Path x:Name="arrow"
                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                      Fill="{DynamicResource ProductTextMutedBrush}"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0" />
                            </Grid>
                        </Border>
                        <Popup x:Name="popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PopupAnimation="Fade">
                            <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border Background="{DynamicResource ProductSurfaceBrush}"
                                        BorderBrush="{DynamicResource ProductBorderStrongBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="4">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="rootBorder" Property="Background" Value="{DynamicResource ProductInputHoverBrush}" />
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{DynamicResource ProductBorderStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
                            <Setter TargetName="arrow" Property="Fill" Value="{DynamicResource ProductAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="contentSite" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="rootBorder" Property="Background" Value="{DynamicResource ProductDisabledBrush}" />
                            <Setter TargetName="rootBorder" Property="BorderBrush" Value="{DynamicResource ProductDisabledBrush}" />
                            <Setter TargetName="arrow" Property="Fill" Value="{DynamicResource ProductDisabledTextBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid MinHeight="{TemplateBinding MinHeight}" SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="box"
                                Width="18"
                                Height="18"
                                Background="{DynamicResource ProductInputBrush}"
                                BorderBrush="{DynamicResource ProductBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                VerticalAlignment="Center">
                            <Path x:Name="check"
                                  Data="M 4 9 L 7 12 L 14 5"
                                  Stroke="{DynamicResource ProductAccentTextBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Visibility="Collapsed" />
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Margin="10,0,0,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource ProductBorderStrongBrush}" />
                            <Setter TargetName="box" Property="Background" Value="{DynamicResource ProductInputHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{DynamicResource ProductAccentBrush}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource ProductAccentBrush}" />
                            <Setter TargetName="check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                            <Setter TargetName="box" Property="Background" Value="{DynamicResource ProductDisabledBrush}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource ProductDisabledBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductTabItemStyle" TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource ProductChromeBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="tabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12,12,0,0"
                            Margin="0,0,4,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource ProductSurfaceRaisedBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="tabBorder" Property="Background" Value="{DynamicResource ProductSurfaceBrush}" />
                            <Setter TargetName="tabBorder" Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
                            <Setter Property="Panel.ZIndex" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ProductDisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductTabControlStyle" TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource ProductSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ProductTabItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel x:Name="headerPanel"
                                  Grid.Row="0"
                                  IsItemsHost="True"
                                  KeyboardNavigation.TabIndex="1"
                                  Panel.ZIndex="1" />
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0,0,12,12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="0" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductContextMenuStyle" TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{DynamicResource ProductSurfaceRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductMenuItemStyle" TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
        <Setter Property="Padding" Value="12,8,12,8" />
        <Setter Property="MinWidth" Value="244" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="menuItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            MinWidth="{TemplateBinding MinWidth}"
                            MinHeight="{TemplateBinding MinHeight}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              ContentSource="Header"
                                              Margin="0,0,24,0"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{DynamicResource ProductTextMutedBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="menuItemBorder" Property="Background" Value="{DynamicResource ProductSurfaceHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource ProductTextMutedBrush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="menuItemBorder" Property="Background" Value="Transparent" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProductMenuSeparatorStyle" TargetType="{x:Type Separator}">
        <Setter Property="Margin" Value="4,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1"
                            Background="{DynamicResource ProductSeparatorBrush}"
                            SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Existing keys retained for current windows. -->
    <Style x:Key="ToolButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="4" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style x:Key="CustomSliderThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="thumb"
                            Width="14"
                            Height="14"
                            Background="{DynamicResource ProductTextBrush}"
                            BorderBrush="{DynamicResource ProductAccentBrush}"
                            BorderThickness="2"
                            CornerRadius="7"
                            SnapsToDevicePixels="True" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Background" Value="{DynamicResource ProductAccentHoverBrush}" />
                            <Setter TargetName="thumb" Property="BorderBrush" Value="{DynamicResource ProductTextBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumb" Property="Background" Value="{DynamicResource ProductAccentBrush}" />
                            <Setter TargetName="thumb" Property="BorderBrush" Value="{DynamicResource ProductTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CustomSliderFilledTrackStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Height" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="4"
                            VerticalAlignment="Center"
                            Background="{DynamicResource ProductAccentBrush}"
                            CornerRadius="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CustomSliderEmptyTrackStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Height" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="4"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            CornerRadius="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CustomSliderStyle" TargetType="Slider">
        <Setter Property="Minimum" Value="1" />
        <Setter Property="Maximum" Value="20" />
        <Setter Property="Value" Value="2" />
        <Setter Property="Width" Value="96" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource ProductAccentBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid MinHeight="28" SnapsToDevicePixels="True">
                        <Border x:Name="rail"
                                Height="4"
                                Background="{DynamicResource ProductBorderBrush}"
                                CornerRadius="2"
                                VerticalAlignment="Center" />
                        <Track x:Name="PART_Track"
                               Height="20"
                               VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge"
                                              Style="{StaticResource CustomSliderFilledTrackStyle}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge"
                                              Style="{StaticResource CustomSliderEmptyTrackStyle}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource CustomSliderThumbStyle}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="rail" Property="Background" Value="{DynamicResource ProductBorderStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="rail" Property="Background" Value="{DynamicResource ProductDisabledBrush}" />
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
