<Window x:Class="parallax.UI.Windows.AnnotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        Title="Parallax Capture - Annotate"
        Width="950" Height="700"
        MinWidth="600" MinHeight="400"
        KeyDown="Window_KeyDown">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                             ResizeBorderThickness="6"
                             GlassFrameThickness="0"
                             CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ─── ICON RESOURCES ─── -->
        
        <!-- Pen -->
        <PathGeometry x:Key="IconPenGeo">M2.5,13 L5.5,10 L10.5,5 L13,2.5 C13.4,2.1 13.4,1.5 13,1.1 L12.9,1 C12.5,0.6 11.9,0.6 11.5,1 L9,3.5 L4,8.5 L1,12.5 Z M1,12.5 L2.5,14</PathGeometry>
        
        <!-- Arrow -->
        <PathGeometry x:Key="IconArrowGeo">M2,14 L14,2 M14,2 L8,4 M14,2 L10,8</PathGeometry>
        
        <!-- Rectangle -->
        <PathGeometry x:Key="IconRectGeo">M2,3 L14,3 L14,13 L2,13 Z</PathGeometry>
        
        <!-- Ellipse -->
        <PathGeometry x:Key="IconEllipseGeo">M8,3 A6,5.5 0 1,0 8,14 A6,5.5 0 1,0 8,3 Z</PathGeometry>
        
        <!-- Highlighter -->
        <PathGeometry x:Key="IconHlGeo">M3,7 L13,7 L13,10 L3,10 Z M4,4 L4,13 M12,4 L12,13</PathGeometry>
        
        <!-- Blur -->
        <PathGeometry x:Key="IconBlurGeo">M8,3 A5,5 0 1,0 8,13 A5,5 0 1,0 8,3 Z M8,4 A4,4 0 1,0 8,12 A4,4 0 1,0 8,4 Z M8,5 A3,3 0 1,0 8,11 A3,3 0 1,0 8,5 Z</PathGeometry>
        
        <!-- Color picker -->
        <PathGeometry x:Key="IconColorGeo">M3,3 A10,10 0 1,0 13,13 A10,10 0 1,0 3,3 Z M6,6 L10,10</PathGeometry>
        
        <!-- Undo -->
        <PathGeometry x:Key="IconUndoGeo">M8,2 C4.7,2 2,4.7 2,8 L0.5,6.5 L0,7 L3,10 L6,7 L5.5,6.5 L4,8 C4,5.2 6.2,3 9,3 C11.8,3 14,5.2 14,8 C14,10.8 11.8,13 9,13 L8,13 L8,14 L9,14 C12.3,14 15,11.3 15,8 C15,4.7 12.3,2 9,2 Z</PathGeometry>
        
        <!-- Clear / Trash -->
        <PathGeometry x:Key="IconClearGeo">M4,14 L5.5,14 L5.5,6 L4,6 Z M7,14 L8.5,14 L8.5,6 L7,6 Z M10,14 L11.5,14 L11.5,6 L10,6 Z M2,4 L5,4 L6,2 L10,2 L11,4 L14,4 L14,5 L2,5 Z</PathGeometry>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ProductSurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource ProductTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="2">
                            <Viewbox Width="16" Height="16"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ProductSurfaceHoverBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ProductBorderStrongBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ProductAccentPressedBrush}" />
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ProductAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButtonIconStyle" TargetType="Button"
               BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style x:Key="UndoClearButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="Auto" />
            <Setter Property="MinWidth" Value="55" />
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style x:Key="ColorSwatchStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ProductBorderBrush}" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource ProductFocusVisualStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ProductFocusBrush}" />
                                <Setter TargetName="border" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="14"
                Background="{DynamicResource ProductSurfaceBrush}"
                BorderBrush="{DynamicResource ProductBorderStrongBrush}"
                BorderThickness="1"
                Margin="6">
            <Border.Effect>
                <DropShadowEffect Color="Black"
                                  Opacity="0.2"
                                  BlurRadius="8"
                                  ShadowDepth="2" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Title Bar -->
                    <RowDefinition Height="Auto" />  <!-- Toolbar -->
                    <RowDefinition Height="*"    />  <!-- Canvas Area -->
                    <RowDefinition Height="Auto" />  <!-- Bottom Bar -->
                </Grid.RowDefinitions>

                <!-- TITLE BAR (draggable) -->
                <Border Grid.Row="0"
                        Background="{DynamicResource ProductChromeBrush}"
                        CornerRadius="14,14,0,0"
                        MouseDown="TitleBar_MouseDown"
                        Padding="12,8">
                    <Grid>
                        <TextBlock Text="Parallax Capture - Annotate"
                                   Style="{StaticResource ProductSectionHeaderTextStyle}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="BtnClose"
                                Content="Close"
                                MinWidth="64"
                                Height="30"
                                Click="BtnClose_Click"
                                HorizontalAlignment="Right"
                                Style="{StaticResource ProductButtonStyle}" />
                    </Grid>
                </Border>

                <!-- TOOLBAR ROW -->
                <Border Grid.Row="1"
                        Background="{DynamicResource ProductSurfaceRaisedBrush}"
                        Padding="8,6">
                    <StackPanel Orientation="Horizontal">

                        <!-- ── Tool Buttons with icons ── -->
                        <Button x:Name="BtnPen" ToolTip="Pen (P)"
                                Tag="Pen"
                                Click="Tool_Click"
                                Style="{StaticResource ToolButtonIconStyle}">
                            <Path Data="{StaticResource IconPenGeo}"
                                  Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent" />
                        </Button>

                        <Button x:Name="BtnArrow" ToolTip="Arrow (A)"
                                Tag="Arrow"
                                Click="Tool_Click"
                                Style="{StaticResource ToolButtonIconStyle}">
                            <Path Data="{StaticResource IconArrowGeo}"
                                  Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Button>

                        <Button x:Name="BtnRect" ToolTip="Rectangle (R)"
                                Tag="Rectangle"
                                Click="Tool_Click"
                                Style="{StaticResource ToolButtonIconStyle}">
                            <Path Data="{StaticResource IconRectGeo}"
                                  Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Button>

                        <Button x:Name="BtnEllipse" ToolTip="Ellipse (E)"
                                Tag="Ellipse"
                                Click="Tool_Click"
                                Style="{StaticResource ToolButtonIconStyle}">
                            <Path Data="{StaticResource IconEllipseGeo}"
                                  Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" />
                        </Button>

                        <Button x:Name="BtnText" ToolTip="Text (T)"
                                Tag="Text"
                                Click="Tool_Click"
                                Style="{StaticResource ToolButtonIconStyle}">
                            <TextBlock Text="T" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource ProductTextBrush}"
                                       FontFamily="Segoe UI" />
                        </Button>

                        <Button x:Name="BtnHighlight" ToolTip="Highlighter (H)"
                                Tag="Highlighter"
                                Click="Tool_Click"
                                Style="{StaticResource ToolButtonIconStyle}">
                            <Path Data="{StaticResource IconHlGeo}"
                                  Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="{DynamicResource ProductAccentBrush}"
                                  Opacity="0.75" />
                        </Button>

                        <Button x:Name="BtnBlur" ToolTip="Blur (B)"
                                Tag="Blur"
                                Click="Tool_Click"
                                Style="{StaticResource ToolButtonIconStyle}">
                            <Path Data="{StaticResource IconBlurGeo}"
                                  Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Opacity="0.8" />
                        </Button>

                        <Separator Width="1" Background="{DynamicResource ProductSeparatorBrush}" Margin="6,0" />

                        <!-- ── Color Picker ── -->
                        <ItemsControl x:Name="ColorSwatches"
                                      VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <Button x:Name="BtnMoreColors"
                                Content="Colors"
                                ToolTip="Choose custom color"
                                MinWidth="66"
                                Height="32"
                                Margin="4,0,0,0"
                                Click="MoreColors_Click"
                                VerticalAlignment="Center"
                                Style="{StaticResource ActionButtonStyle}" />

                        <Separator Width="1" Background="{DynamicResource ProductSeparatorBrush}" Margin="6,0" />

                        <!-- ── Stroke Thickness ── -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Stroke"
                                       Foreground="{DynamicResource ProductTextMutedBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <Border BorderBrush="{DynamicResource ProductBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="{DynamicResource ProductInputBrush}"
                                    Padding="6,0">
                                <Grid>
                                    <Slider x:Name="ThicknessSlider"
                                             Minimum="1" Maximum="20" Value="2"
                                             Width="88" Height="28"
                                             VerticalAlignment="Center"
                                             ToolTip="Stroke size: 2"
                                             ValueChanged="ThicknessSlider_ValueChanged"
                                             Style="{StaticResource CustomSliderStyle}" />
                                </Grid>
                            </Border>
                            <TextBlock x:Name="ThicknessValue"
                                       Text="2"
                                       Foreground="{DynamicResource ProductTextMutedBrush}"
                                       FontSize="11"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       MinWidth="14"
                                       TextAlignment="Center"
                                       Margin="3,0,0,0" />
                        </StackPanel>

                        <Separator Width="1" Background="{DynamicResource ProductSeparatorBrush}" Margin="6,0" />

                        <!-- ── Zoom Controls ── -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnZoomOut"
                                     ToolTip="Zoom out"
                                     Click="BtnZoomOut_Click"
                                     FontSize="14" FontWeight="Bold"
                                     VerticalAlignment="Center"
                                     Margin="0,0,2,0"
                                     Style="{StaticResource ToolButtonIconStyle}">
                                <Path Data="M 2 8 L 14 8"
                                      Stroke="{DynamicResource ProductTextBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Button>
                            <TextBlock x:Name="TxtZoomLevel"
                                       Text="100%"
                                       Foreground="{DynamicResource ProductTextMutedBrush}"
                                       FontSize="10"
                                       FontFamily="Segoe UI"
                                       Width="38"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center" />
                            <Button x:Name="BtnZoomIn"
                                     ToolTip="Zoom in"
                                     Click="BtnZoomIn_Click"
                                     FontSize="14" FontWeight="Bold"
                                     VerticalAlignment="Center"
                                     Margin="2,0,2,0"
                                     Style="{StaticResource ToolButtonIconStyle}">
                                <Path Data="M 8 2 L 8 14 M 2 8 L 14 8"
                                      Stroke="{DynamicResource ProductTextBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Button>
                            <Button x:Name="BtnZoomReset"
                                     ToolTip="Reset zoom"
                                     Click="BtnZoomReset_Click"
                                     FontSize="10"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource ToolButtonIconStyle}">
                                <TextBlock Text="1:1"
                                           Foreground="{DynamicResource ProductTextBrush}"
                                           FontFamily="Segoe UI"
                                           FontSize="10"
                                           FontWeight="SemiBold" />
                            </Button>
                        </StackPanel>

                        <Separator Width="1" Background="{DynamicResource ProductSeparatorBrush}" Margin="6,0" />

                        <!-- ── Undo (wider with icon) ── -->
                        <Button x:Name="BtnUndo"
                                ToolTip="Undo (Ctrl+Z)"
                                Click="BtnUndo_Click"
                                Style="{StaticResource UndoClearButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconUndoGeo}"
                                      Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="1.0"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="12" Height="12"
                                      Margin="0,0,4,0" />
                                <TextBlock Text="Undo" FontSize="11" />
                            </StackPanel>
                        </Button>

                        <!-- ── Clear (wider with icon) ── -->
                        <Button x:Name="BtnClear"
                                ToolTip="Clear all annotations"
                                Click="BtnClear_Click"
                                Style="{StaticResource UndoClearButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconClearGeo}"
                                      Stroke="{DynamicResource ProductTextBrush}" StrokeThickness="0.8"
                                      Fill="{DynamicResource ProductTextBrush}"
                                      Width="12" Height="12"
                                      Margin="0,0,4,0" />
                                <TextBlock Text="Clear all" FontSize="11" />
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- ANNOTATION CANVAS AREA -->
                <ScrollViewer Grid.Row="2"
                              Background="{DynamicResource ProductInputBrush}"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="ContentGrid">
                        <Grid.LayoutTransform>
                            <ScaleTransform x:Name="ZoomTransform"
                                            ScaleX="1" ScaleY="1" />
                        </Grid.LayoutTransform>
                        <Image x:Name="ScreenshotImage"
                               Stretch="None"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top" />

                        <Canvas x:Name="AnnotationCanvas"
                                Background="Transparent"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                MouseDown="AnnotationCanvas_MouseDown"
                                MouseMove="AnnotationCanvas_MouseMove"
                                MouseUp="AnnotationCanvas_MouseUp"
                                Cursor="Cross" />

                        <Canvas x:Name="TextAdornerCanvas"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Panel.ZIndex="20">
                            <Border x:Name="FloatingTextToolbar"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource ProductChromeBrush}"
                                    BorderBrush="{DynamicResource ProductBorderStrongBrush}"
                                    BorderThickness="1"
                                    CornerRadius="7"
                                    Padding="6"
                                    Canvas.Left="0"
                                    Canvas.Top="0">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnTextColor"
                                            ToolTip="Apply text color"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,6,0"
                                            Click="TextColorButton_Click"
                                            Style="{StaticResource ToolButtonStyle}">
                                        <Grid Width="18" Height="18">
                                            <Ellipse Stroke="{DynamicResource ProductTextBrush}"
                                                     StrokeThickness="1"
                                                     Fill="Transparent" />
                                            <Rectangle x:Name="TextColorPreview"
                                                       Width="10"
                                                       Height="10"
                                                       RadiusX="2"
                                                       RadiusY="2"
                                                       Fill="Red"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <ComboBox x:Name="CmbTextFontFamily"
                                              Width="132"
                                              Height="32"
                                              Margin="0,0,6,0"
                                              Style="{StaticResource ProductComboBoxStyle}"
                                              SelectionChanged="TextFontFamily_SelectionChanged">
                                        <ComboBoxItem Content="Segoe UI" IsSelected="True" />
                                        <ComboBoxItem Content="Arial" />
                                        <ComboBoxItem Content="Calibri" />
                                        <ComboBoxItem Content="Consolas" />
                                        <ComboBoxItem Content="Georgia" />
                                    </ComboBox>
                                    <Button Content="B"
                                            Tag="Bold"
                                            ToolTip="Bold selected text"
                                            Width="32"
                                            Height="32"
                                            FontWeight="Bold"
                                            Margin="0,0,4,0"
                                            Click="TextFormatButton_Click"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="I"
                                            Tag="Italic"
                                            ToolTip="Italic selected text"
                                            Width="32"
                                            Height="32"
                                            FontStyle="Italic"
                                            Margin="0,0,4,0"
                                            Click="TextFormatButton_Click"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="U"
                                            Tag="Underline"
                                            ToolTip="Underline selected text"
                                            Width="32"
                                            Height="32"
                                            Margin="0,0,4,0"
                                            Click="TextFormatButton_Click"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="S"
                                            Tag="Strike"
                                            ToolTip="Strikethrough selected text"
                                            Width="32"
                                            Height="32"
                                            Click="TextFormatButton_Click"
                                            Style="{StaticResource ToolButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Button x:Name="TextMoveHandle"
                                    Visibility="Collapsed"
                                    Width="24"
                                    Height="24"
                                    Padding="0"
                                    Cursor="SizeAll"
                                    ToolTip="Move text"
                                    PreviewMouseLeftButtonDown="TextMoveHandle_MouseLeftButtonDown"
                                    PreviewMouseMove="TextMoveHandle_MouseMove"
                                    PreviewMouseLeftButtonUp="TextMoveHandle_MouseLeftButtonUp"
                                    Style="{StaticResource ToolButtonStyle}">
                                <Path Data="M 8 2 L 8 14 M 2 8 L 14 8 M 8 2 L 5 5 M 8 2 L 11 5 M 14 8 L 11 5 M 14 8 L 11 11 M 8 14 L 5 11 M 8 14 L 11 11 M 2 8 L 5 5 M 2 8 L 5 11"
                                      Stroke="{DynamicResource ProductTextBrush}"
                                      StrokeThickness="1.4"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="16"
                                      Height="16"
                                      Stretch="Uniform" />
                            </Button>
                        </Canvas>
                    </Grid>
                </ScrollViewer>

                <!-- BOTTOM ACTION BAR -->
                <Border Grid.Row="3"
                        Background="{DynamicResource ProductChromeBrush}"
                        Padding="10,8"
                        CornerRadius="0,0,6,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Save feedback: green text that auto-fades -->
                        <TextBlock x:Name="TxtStatus"
                                   Grid.Column="0"
                                   Text=""
                                   Foreground="{DynamicResource ProductSuccessBrush}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Opacity="0" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">

                            <Button x:Name="BtnCopyClipboard"
                                    Content="Copy image"
                                    Height="32" Padding="12,6"
                                    Click="BtnCopyClipboard_Click"
                                    Style="{StaticResource ActionButtonStyle}" />

                            <Button x:Name="BtnSave"
                                    Content="Save image"
                                    Height="32" Padding="12,6"
                                    Margin="6,0,0,0"
                                    Click="BtnSave_Click"
                                    Style="{StaticResource ActionButtonStyle}" />

                            <Button x:Name="BtnSaveAs"
                                    Content="Save as"
                                    Height="32" Padding="12,6"
                                    Margin="6,0,0,0"
                                    Click="BtnSaveAs_Click"
                                    Style="{StaticResource ActionButtonStyle}" />

                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
