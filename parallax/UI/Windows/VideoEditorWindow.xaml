<Window x:Class="parallax.UI.Windows.VideoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="CanResizeWithGrip"
        Width="1040" Height="720"
        MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Title="Parallax Video Editor"
        KeyDown="Window_KeyDown"
        Style="{StaticResource ProductWindowStyle}">

    <Window.Resources>
        <Style x:Key="EditorButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style x:Key="EditorPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductPrimaryButtonStyle}">
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="16,8" />
        </Style>

        <Style x:Key="EditorWarningButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="{StaticResource ProductWarningSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ProductWarningBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ProductTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="EditorChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource ProductButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="TrimTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ProductTextBoxStyle}">
            <Setter Property="Width" Value="92" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="EditorFieldGroupStyle" TargetType="Border" BasedOn="{StaticResource ProductSectionBorderStyle}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorMonoTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ProductTextMutedBrush}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="14"
            Background="{StaticResource ProductWindowBrush}"
            BorderBrush="{StaticResource ProductBorderStrongBrush}"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.45"
                              BlurRadius="18" ShadowDepth="4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource ProductChromeBrush}"
                    CornerRadius="14,14,0,0"
                    MouseDown="TitleBar_MouseDown"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Parallax Video Editor"
                                   Style="{StaticResource ProductSectionHeaderTextStyle}"
                                   FontSize="14"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Space: play/pause   M: mute   Esc: close"
                                   Foreground="{StaticResource ProductTextSubtleBrush}"
                                   FontSize="11"
                                   FontFamily="Segoe UI"
                                   Margin="14,1,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock x:Name="TxtFileName"
                               Grid.Column="1"
                               Text=""
                               Foreground="{StaticResource ProductTextSubtleBrush}"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis"
                               Margin="16,0,12,0" />

                    <Button x:Name="BtnClose"
                            Grid.Column="2"
                            Content="X"
                            ToolTip="Close editor (Esc)"
                            Click="BtnClose_Click"
                            Style="{StaticResource EditorChromeButtonStyle}" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource ProductInputBrush}"
                    BorderBrush="{StaticResource ProductSeparatorBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="12,12,12,0"
                    ClipToBounds="True">
                <Grid>
                    <MediaElement x:Name="VideoPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  MediaOpened="VideoPlayer_MediaOpened"
                                  MediaEnded="VideoPlayer_MediaEnded"
                                  MediaFailed="VideoPlayer_MediaFailed"
                                  ScrubbingEnabled="True"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />

                    <Border x:Name="PlayOverlay"
                            Background="{StaticResource ProductOverlayBrush}"
                            BorderBrush="{StaticResource ProductBorderStrongBrush}"
                            BorderThickness="1"
                            CornerRadius="42"
                            Width="84" Height="84"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            MouseDown="PlayOverlay_MouseDown">
                        <Path Data="M 0 0 L 28 16 L 0 32 Z"
                              Fill="{StaticResource ProductTextBrush}"
                              Width="32"
                              Height="32"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="4,0,0,0" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource ProductSurfaceBrush}"
                    BorderBrush="{StaticResource ProductSeparatorBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="14,12"
                    Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Timeline"
                                   Style="{StaticResource ProductSectionLabelStyle}"
                                   VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="Drag the blue handles to set the trim range. Click the track to move the playhead."
                                   Foreground="{StaticResource ProductTextSubtleBrush}"
                                   FontSize="11"
                                   FontFamily="Segoe UI"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="12,0"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="12,0">
                            <TextBlock x:Name="TxtCurrentTime"
                                       Text="00:00"
                                       Style="{StaticResource EditorMonoTextStyle}" />
                            <TextBlock Text=" / "
                                       Foreground="{StaticResource ProductTextSubtleBrush}"
                                       FontSize="13"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="TxtTotalTime"
                                       Text="00:00"
                                       Style="{StaticResource EditorMonoTextStyle}" />
                        </StackPanel>

                        <TextBlock x:Name="TxtFFmpegStatus"
                                   Grid.Column="3"
                                   Text=""
                                   Foreground="{StaticResource ProductWarningBrush}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnPlayPause"
                                    ToolTip="Play or pause video (Space)"
                                    Click="BtnPlayPause_Click"
                                    Style="{StaticResource EditorPrimaryButtonStyle}"
                                    Width="112" />
                            <Button x:Name="BtnRestart"
                                    ToolTip="Restart video from the beginning"
                                    Click="BtnRestart_Click"
                                    Style="{StaticResource EditorButtonStyle}"
                                    Width="98"
                                    Margin="8,0,0,0" />
                            <Button x:Name="BtnMute"
                                    ToolTip="Toggle audio (M)"
                                    Click="BtnMute_Click"
                                    Style="{StaticResource EditorButtonStyle}"
                                    Width="104"
                                    Margin="8,0,0,0" />
                        </StackPanel>

                        <Canvas x:Name="TrimTimelineCanvas"
                                Grid.Column="1"
                                Height="64"
                                Margin="18,0,0,0"
                                Cursor="Hand"
                                Background="Transparent"
                                SizeChanged="TrimTimelineCanvas_SizeChanged"
                                MouseLeftButtonDown="TrimTimelineCanvas_MouseLeftButtonDown"
                                MouseMove="TrimTimelineCanvas_MouseMove"
                                MouseLeftButtonUp="TrimTimelineCanvas_MouseLeftButtonUp">
                            <Rectangle x:Name="TimelineTrack"
                                       Height="8"
                                       RadiusX="4"
                                       RadiusY="4"
                                       Fill="{StaticResource ProductInputHoverBrush}"
                                       Stroke="{StaticResource ProductBorderStrongBrush}"
                                       StrokeThickness="1"
                                       Canvas.Top="28" />
                            <Rectangle x:Name="TimelineSelectedRange"
                                       Height="10"
                                       RadiusX="5"
                                       RadiusY="5"
                                       Fill="{StaticResource ProductAccentBrush}"
                                       Opacity="0.75"
                                       Canvas.Top="27" />
                            <Line x:Name="TimelinePlayhead"
                                  Y1="10"
                                  Y2="54"
                                  Stroke="{StaticResource ProductTextBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                            <Rectangle x:Name="TrimInHandle"
                                       Width="12"
                                       Height="34"
                                       RadiusX="3"
                                       RadiusY="3"
                                       Fill="{StaticResource ProductAccentBrush}"
                                       Stroke="{StaticResource ProductAccentTextBrush}"
                                       StrokeThickness="1"
                                       Canvas.Top="15" />
                            <Rectangle x:Name="TrimOutHandle"
                                       Width="12"
                                       Height="34"
                                       RadiusX="3"
                                       RadiusY="3"
                                       Fill="{StaticResource ProductAccentBrush}"
                                       Stroke="{StaticResource ProductAccentTextBrush}"
                                       StrokeThickness="1"
                                       Canvas.Top="15" />
                        </Canvas>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource ProductSurfaceRaisedBrush}"
                    BorderBrush="{StaticResource ProductSeparatorBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Start"
                                   Style="{StaticResource ProductSectionLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox x:Name="TxtTrimStart"
                                 Text="00:00"
                                 TextChanged="TrimTextBox_TextChanged"
                                 Style="{StaticResource TrimTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="End"
                                   Style="{StaticResource ProductSectionLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox x:Name="TxtTrimOut"
                                 Text="00:00"
                                 TextChanged="TrimTextBox_TextChanged"
                                 Style="{StaticResource TrimTextBoxStyle}" />
                    </StackPanel>

                    <Border Grid.Column="2"
                            BorderBrush="{StaticResource ProductBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,7"
                            Background="{StaticResource ProductInputBrush}"
                            VerticalAlignment="Center"
                            Margin="14,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Duration"
                                       Foreground="{StaticResource ProductTextSubtleBrush}"
                                       FontSize="11"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock x:Name="TxtTrimDuration"
                                       Text="00:00"
                                       Foreground="{StaticResource ProductSuccessBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Button x:Name="BtnPreviewTrim"
                            Grid.Column="3"
                            ToolTip="Play only the selected trim range"
                            Style="{StaticResource EditorButtonStyle}"
                            Width="120"
                            HorizontalAlignment="Left"
                            Margin="14,0,0,0"
                            Click="BtnPreviewTrim_Click" />

                    <Button x:Name="BtnDownloadFFmpeg"
                            Grid.Column="4"
                            Content="Download FFmpeg"
                            ToolTip="Download FFmpeg for video trimming"
                            Click="BtnDownloadFFmpeg_Click"
                            Style="{StaticResource EditorWarningButtonStyle}"
                            Visibility="Collapsed"
                            Width="150"
                            Margin="12,0,0,0" />
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Background="{StaticResource ProductChromeBrush}"
                    Padding="14,12"
                    CornerRadius="0,0,14,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnOpenVideo"
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="Open Video"
                            ToolTip="Open a video file for editing"
                            Click="BtnOpenVideo_Click"
                            Style="{StaticResource EditorButtonStyle}"
                            Width="110"
                            Margin="0,0,12,0" />

                    <Border Grid.Column="1"
                            Grid.Row="0"
                            Background="{StaticResource ProductInputBrush}"
                            BorderBrush="{StaticResource ProductBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,7">
                        <TextBlock x:Name="TxtEditorStatus"
                                   Text="Save to keep this recording, or close to discard."
                                   Foreground="{StaticResource ProductTextSubtleBrush}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <WrapPanel Grid.Row="1"
                               Grid.ColumnSpan="2"
                               HorizontalAlignment="Right"
                               Margin="0,10,0,0">
                        <Button x:Name="BtnSaveTrimmed"
                                Content="Save Trimmed"
                                ToolTip="Apply trim and save a new video"
                                Click="BtnSaveTrimmed_Click"
                                Style="{StaticResource EditorPrimaryButtonStyle}"
                                Width="142"
                                Margin="0,0,8,0" />

                        <Button x:Name="BtnSaveFrame"
                                Content="Save Frame"
                                ToolTip="Save the current video frame as a PNG"
                                Click="BtnSaveFrame_Click"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="116"
                                Margin="0,0,8,0" />

                        <Button x:Name="BtnExportGif"
                                Content="Export GIF"
                                ToolTip="Export the selected trim range as a GIF"
                                Click="BtnExportGif_Click"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="112"
                                Margin="0,0,8,0" />

                        <Button x:Name="BtnSaveOriginal"
                                Content="Save Original"
                                ToolTip="Save without trimming"
                                Click="BtnSaveOriginal_Click"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="128"
                                Margin="0,0,8,0" />

                        <Button x:Name="BtnCloseEditor"
                                Content="Close"
                                ToolTip="Close editor (Esc)"
                                Click="BtnCloseEditor_Click"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="88" />
                    </WrapPanel>
                </Grid>
            </Border>

            <ResizeGrip Grid.Row="4"
                        Width="18" Height="18"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,4,4"
                        Panel.ZIndex="10"
                        Opacity="0.65" />
        </Grid>
    </Border>
</Window>
