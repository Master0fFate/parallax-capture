<Window x:Class="parallax.UI.Windows.VideoEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        Width="880" Height="660"
        WindowStartupLocation="CenterScreen"
        Title="parallax - Video Editor"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="EditorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A4E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3A3A7E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF007ACC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrimTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Background" Value="#1A1A2E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#555" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="6"
            Background="#FF1E1E2E"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.4"
                              BlurRadius="16" ShadowDepth="4" />
        </Border.Effect>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- Title bar -->
                <RowDefinition Height="*"    />   <!-- Video area -->
                <RowDefinition Height="Auto" />   <!-- Timeline + playback controls -->
                <RowDefinition Height="Auto" />   <!-- Trim controls -->
                <RowDefinition Height="Auto" />   <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- ════ TITLE BAR ════ -->
            <Border Grid.Row="0"
                    Background="#FF151525"
                    CornerRadius="6,6,0,0"
                    MouseDown="TitleBar_MouseDown"
                    Padding="14,10">
                <Grid>
                    <TextBlock Text="parallax -- Video Editor"
                               Foreground="#DDD"
                               FontSize="14"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <TextBlock x:Name="TxtFileName"
                                   Text=""
                                   Foreground="#888"
                                   FontSize="11"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0" />
                        <Button x:Name="BtnClose"
                                Content="X"
                                Width="26" Height="22"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="11"
                                Click="BtnClose_Click"
                                Cursor="Hand" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════ VIDEO PLAYBACK ════ -->
            <Border Grid.Row="1"
                    Background="#0A0A1A"
                    BorderThickness="0">
                <Grid>
                    <MediaElement x:Name="VideoPlayer"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  MediaOpened="VideoPlayer_MediaOpened"
                                  MediaEnded="VideoPlayer_MediaEnded"
                                  MediaFailed="VideoPlayer_MediaFailed"
                                  ScrubbingEnabled="True"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />

                    <!-- Center play overlay (shown when paused) -->
                    <Border x:Name="PlayOverlay"
                            Background="#88000000"
                            CornerRadius="40"
                            Width="72" Height="72"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            MouseDown="PlayOverlay_MouseDown">
                        <TextBlock Text="▶"
                                   Foreground="White"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- ════ TIMELINE + PLAYBACK CONTROLS ════ -->
            <Border Grid.Row="2"
                    Background="#FF151525"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Play/Pause + Restart -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <Button x:Name="BtnPlayPause"
                                Content="▶  Play"
                                ToolTip="Play/Pause (Space)"
                                Click="BtnPlayPause_Click"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="90" />
                        <Button x:Name="BtnRestart"
                                Content="⏮"
                                ToolTip="Restart"
                                Click="BtnRestart_Click"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="40" Margin="4,0,0,0" />
                        <Separator Width="1" Background="#444"
                                   Margin="8,0" />
                        <!-- Mute toggle (moved here to avoid trim row clutter) -->
                        <Button x:Name="BtnMute"
                                Content="🔊  Mute"
                                ToolTip="Toggle mute (M)"
                                Click="BtnMute_Click"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="90" />
                    </StackPanel>

                    <!-- Timeline slider -->
                    <Slider x:Name="TimelineSlider"
                            Grid.Column="1"
                            Minimum="0" Maximum="1" Value="0"
                            Margin="14,0"
                            VerticalAlignment="Center"
                            ValueChanged="TimelineSlider_ValueChanged"
                            PreviewMouseDown="TimelineSlider_PreviewMouseDown"
                            PreviewMouseUp="TimelineSlider_PreviewMouseUp"
                            Cursor="Hand" />

                    <!-- Time labels -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <TextBlock x:Name="TxtCurrentTime"
                                   Text="00:00"
                                   Foreground="#AAA"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" / "
                                   Foreground="#666"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtTotalTime"
                                   Text="00:00"
                                   Foreground="#AAA"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- FFmpeg status -->
                    <TextBlock x:Name="TxtFFmpegStatus"
                               Grid.Column="3"
                               Text=""
                               Foreground="#FFAA33"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- ════ TRIM CONTROLS (spacious two-section layout) ════ -->
            <Border Grid.Row="3"
                    Background="#FF1A1A2E"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- ── TRIM FROM section ── -->
                    <Border Grid.Column="0"
                            BorderBrush="#444"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="From"
                                       Foreground="#CCC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBox x:Name="TxtTrimStart"
                                     Text="00:00"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource TrimTextBoxStyle}"
                                     Width="70" />
                            <Button Content="◀ Mark"
                                    ToolTip="Set start to current position"
                                    Click="BtnSetTrimIn_Click"
                                    Style="{StaticResource EditorButtonStyle}"
                                    Width="70" Margin="4,0,0,0"
                                    FontSize="11" />
                        </StackPanel>
                    </Border>

                    <!-- ── TRIM TO section ── -->
                    <Border Grid.Column="1"
                            BorderBrush="#444"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="To"
                                       Foreground="#CCC"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBox x:Name="TxtTrimOut"
                                     Text="00:00"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource TrimTextBoxStyle}"
                                     Width="70" />
                            <Button Content="▶ Mark"
                                    ToolTip="Set end to current position"
                                    Click="BtnSetTrimOut_Click"
                                    Style="{StaticResource EditorButtonStyle}"
                                    Width="70" Margin="4,0,0,0"
                                    FontSize="11" />
                        </StackPanel>
                    </Border>

                    <!-- ── QUICK TRIM BUTTONS ── -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Margin="0,0,10,0">
                        <Button Content="⏪ 5s"
                                ToolTip="Move trim start back 5 seconds"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="55" FontSize="11"
                                Click="BtnTrimMinus5_Click" Margin="0,0,2,0" />
                        <Button Content="5s ⏩"
                                ToolTip="Move trim end forward 5 seconds"
                                Style="{StaticResource EditorButtonStyle}"
                                Width="55" FontSize="11"
                                Click="BtnTrimPlus5_Click" Margin="0,0,2,0" />
                    </StackPanel>

                    <!-- ── DURATION DISPLAY ── -->
                    <Border Grid.Column="3"
                            BorderBrush="#333"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,6,0"
                            Background="#151525"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Duration:"
                                       Foreground="#888"
                                       FontSize="11"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBlock x:Name="TxtTrimDuration"
                                       Text="00:00"
                                       Foreground="#4F4"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- DOWNLOAD FFMPEG button - shown only when needed -->
                    <Button x:Name="BtnDownloadFFmpeg"
                            Grid.Column="5"
                            Content="Download FFmpeg"
                            ToolTip="Download FFmpeg for video trimming"
                            Click="BtnDownloadFFmpeg_Click"
                            Style="{StaticResource EditorButtonStyle}"
                            Visibility="Collapsed"
                            Width="130"
                            Background="#FF553300"
                            HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- ════ ACTION BAR ════ -->
            <Border Grid.Row="4"
                    Background="#FF151525"
                    Padding="14,10"
                    CornerRadius="0,0,6,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnOpenVideo"
                            Grid.Column="0"
                            Content="Open"
                            ToolTip="Open a video file for editing"
                            Click="BtnOpenVideo_Click"
                            Style="{StaticResource EditorButtonStyle}"
                            Width="60" Margin="0,0,10,0" />

                    <TextBlock x:Name="TxtEditorStatus"
                               Grid.Column="1"
                               Text="Save to keep this recording, or close to discard."
                               Foreground="#666"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center" />

                    <Button x:Name="BtnSaveTrimmed"
                            Grid.Column="2"
                            Content="Save Trimmed"
                            ToolTip="Apply trim and save"
                            Click="BtnSaveTrimmed_Click"
                            Style="{StaticResource EditorButtonStyle}"
                            Width="120" Margin="0,0,8,0"
                            Background="#FF006644" />

                    <Button x:Name="BtnSaveOriginal"
                            Grid.Column="3"
                            Content="Save Original"
                            ToolTip="Save without trimming"
                            Click="BtnSaveOriginal_Click"
                            Style="{StaticResource EditorButtonStyle}"
                            Width="100" Margin="0,0,8,0" />

                    <Button x:Name="BtnCloseEditor"
                            Grid.Column="4"
                            Content="Close"
                            Click="BtnCloseEditor_Click"
                            Style="{StaticResource EditorButtonStyle}"
                            Width="80" />
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
