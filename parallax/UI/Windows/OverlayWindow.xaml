<Window x:Class="parallax.UI.Windows.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        Cursor="Cross"
        Title="Parallax Capture Overlay">

    <Grid>
        <Canvas x:Name="MainCanvas"
                Background="Transparent"
                MouseDown="Canvas_MouseDown"
                MouseMove="Canvas_MouseMove"
                MouseUp="Canvas_MouseUp">

            <!-- DIMMING OVERLAY — drawn as a Path with a hole punched out for the selection -->
            <Path x:Name="DimPath"
                  Fill="{StaticResource ProductOverlayBrush}"
                  IsHitTestVisible="False" />

            <!-- SELECTION BORDER — the white/blue marching ants rectangle -->
            <Rectangle x:Name="SelectionRect"
                       Stroke="{StaticResource ProductAccentBrush}"
                       StrokeThickness="1.5"
                       StrokeDashArray="4 2"
                       Fill="Transparent"
                       IsHitTestVisible="False"
                       Visibility="Collapsed" />

            <!-- SIZE LABEL — shows WxH of selection in real time -->
            <Border x:Name="SizeLabel"
                    Background="{StaticResource ProductOverlayBrush}"
                    CornerRadius="3"
                    Padding="6,3"
                    IsHitTestVisible="False"
                    Visibility="Collapsed">
                <TextBlock x:Name="SizeLabelText"
                           Foreground="White"
                           FontSize="11"
                           FontFamily="Segoe UI" />
            </Border>

        <!-- CROSSHAIR LINES — full-screen horizontal and vertical lines -->
        <Line x:Name="CrosshairH"
              Stroke="#80FFFFFF"
              StrokeThickness="1"
              IsHitTestVisible="False"
              Visibility="Collapsed" />
        <Line x:Name="CrosshairV"
              Stroke="#80FFFFFF"
              StrokeThickness="1"
              IsHitTestVisible="False"
              Visibility="Collapsed" />

        </Canvas>

        <!-- INSTRUCTION LABEL — rendered over the canvas, properly centered using Grid layout (KAM #2) -->
        <Border x:Name="InstructionBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource ProductOverlayBrush}"
                CornerRadius="6"
                Padding="14,8"
                IsHitTestVisible="False"
                Margin="0,0,0,40">
            <TextBlock Text="Drag to select a region. Press Esc to cancel."
                       Foreground="White"
                       FontSize="13"
                       FontFamily="Segoe UI" />
        </Border>
    </Grid>
</Window>
