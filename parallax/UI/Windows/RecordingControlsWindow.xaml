<Window x:Class="parallax.UI.Windows.RecordingControlsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parallax Capture Recording Controls"
        Width="318"
        Height="58"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowActivated="False"
        ShowInTaskbar="False"
        Background="{DynamicResource ProductSurfaceRaisedBrush}"
        Style="{StaticResource ProductWindowStyle}">
    <Border Background="{DynamicResource ProductSurfaceRaisedBrush}"
            BorderBrush="{DynamicResource ProductBorderStrongBrush}"
            BorderThickness="1"
            Padding="10"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Ellipse Width="8"
                         Height="8"
                         Fill="{DynamicResource ProductDangerHoverBrush}"
                         Margin="0,0,7,0"
                         VerticalAlignment="Center" />
                <TextBlock Text="Recording"
                           Style="{StaticResource ProductSectionHeaderTextStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <TextBlock x:Name="ElapsedText"
                       Grid.Column="1"
                       Text="00:00:00"
                       FontFamily="Consolas"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ProductTextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="12,0" />

            <Button x:Name="StopButton"
                    Grid.Column="2"
                    Content="Stop recording"
                    MinWidth="116"
                    MinHeight="34"
                    Click="StopButton_Click"
                    Style="{StaticResource ProductDangerButtonStyle}" />
        </Grid>
    </Border>
</Window>
