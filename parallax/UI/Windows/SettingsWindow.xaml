<Window x:Class="parallax.UI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="parallax Settings"
        Width="480" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1E1E2E"
        Foreground="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- SECTION: Save Folder -->
        <TextBlock Grid.Row="0" Text="Save Folder" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,4" />
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtSaveFolder"
                     Grid.Column="0"
                     Background="#FF2A2A3E"
                     Foreground="White"
                     BorderBrush="#555"
                     Padding="6,4"
                     Height="30" />
            <Button Grid.Column="1"
                    Content="Browse"
                    Width="70" Height="30"
                    Margin="6,0,0,0"
                    Click="BtnBrowse_Click"
                    Background="#FF3A3A5E"
                    Foreground="White"
                    BorderThickness="0" />
        </Grid>

        <!-- SECTION: Image Format -->
        <TextBlock Grid.Row="2" Text="Image Format" Foreground="#AAAACC" FontSize="11" Margin="0,0,0,4" />
        <ComboBox x:Name="CmbFormat"
                  Grid.Row="3"
                  Height="30"
                  Margin="0,0,0,16"
                  Background="#FF2A2A3E"
                  Foreground="Black"
                  BorderBrush="#555">
            <ComboBoxItem Content="PNG" Tag="png" IsSelected="True" Foreground="Black" />
            <ComboBoxItem Content="JPEG" Tag="jpg" Foreground="Black" />
            <ComboBoxItem Content="BMP" Tag="bmp" Foreground="Black" />
        </ComboBox>

        <!-- SECTION: Checkboxes -->
        <StackPanel Grid.Row="4" Margin="0,0,0,16">
            <CheckBox x:Name="ChkCopyClipboard"
                      Content="Copy to clipboard after capture"
                      Foreground="White"
                      IsChecked="True" />
            <CheckBox x:Name="ChkAutoSave"
                      Content="Auto-save without annotation window"
                      Foreground="White" />
            <CheckBox x:Name="ChkSeparateFolders"
                      Content="Separate videos and images into subfolders"
                      Foreground="White"
                      ToolTip="Creates videos/ and images/ folders inside the save directory" />
            <CheckBox x:Name="ChkStartWindows"
                      Content="Start with Windows"
                      Foreground="White" />
        </StackPanel>

        <!-- SPACER -->
        <Grid Grid.Row="5" />

        <!-- SAVE BUTTON -->
        <Button Grid.Row="6"
                Content="Save Settings"
                Height="34"
                Background="#FF007ACC"
                Foreground="White"
                BorderThickness="0"
                FontSize="13"
                Click="BtnSave_Click" />
    </Grid>
</Window>
