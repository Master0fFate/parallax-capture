<Window x:Class="parallax.UI.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parallax Capture Settings"
        Width="660" Height="620"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Style="{StaticResource ProductWindowStyle}"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Settings"
                       Style="{StaticResource ProductHeaderTextStyle}" />
            <TextBlock Text="Choose where captures go and how shortcuts work."
                       Style="{StaticResource ProductCaptionTextStyle}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <TabControl Grid.Row="1" Style="{StaticResource ProductTabControlStyle}">
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Style="{StaticResource ProductSectionBorderStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Save location"
                                           Style="{StaticResource ProductSectionHeaderTextStyle}" />
                                <TextBlock Text="Choose the folder used for screenshots and recordings."
                                           TextWrapping="Wrap"
                                           Style="{StaticResource ProductCaptionTextStyle}"
                                           Margin="0,4,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtSaveFolder"
                                             Grid.Column="0"
                                             Style="{StaticResource ProductTextBoxStyle}" />
                                    <Button Grid.Column="1"
                                            Content="Choose folder"
                                            MinWidth="112"
                                            Margin="8,0,0,0"
                                            Click="BtnBrowse_Click"
                                            Style="{StaticResource ProductButtonStyle}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ProductSectionBorderStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Image defaults"
                                           Style="{StaticResource ProductSectionHeaderTextStyle}" />
                                <TextBlock Text="Pick the file type used when saving screenshots."
                                           TextWrapping="Wrap"
                                           Style="{StaticResource ProductCaptionTextStyle}"
                                           Margin="0,4,0,10" />
                                <TextBlock Text="Image format"
                                           Style="{StaticResource ProductSectionLabelStyle}"
                                           Margin="0,0,0,4" />
                                <ComboBox x:Name="CmbFormat"
                                          Width="180"
                                          HorizontalAlignment="Left"
                                          Style="{StaticResource ProductComboBoxStyle}">
                                    <ComboBoxItem Content="PNG" Tag="png" IsSelected="True" />
                                    <ComboBoxItem Content="JPEG" Tag="jpg" />
                                    <ComboBoxItem Content="BMP" Tag="bmp" />
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ProductSectionBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Capture behavior"
                                           Style="{StaticResource ProductSectionHeaderTextStyle}" />
                                <TextBlock Text="Control what happens after a capture is taken."
                                           TextWrapping="Wrap"
                                           Style="{StaticResource ProductCaptionTextStyle}"
                                           Margin="0,4,0,10" />
                                <CheckBox x:Name="ChkCopyClipboard"
                                          Content="Copy captures to clipboard"
                                          Style="{StaticResource ProductCheckBoxStyle}"
                                          IsChecked="True" />
                                <CheckBox x:Name="ChkAutoSave"
                                          Content="Save captures automatically"
                                          Style="{StaticResource ProductCheckBoxStyle}" />
                                <TextBlock Text="The editor still opens so you can review, annotate, or copy."
                                           TextWrapping="Wrap"
                                           Style="{StaticResource ProductCaptionTextStyle}"
                                           Margin="28,0,0,8" />
                                <CheckBox x:Name="ChkSeparateFolders"
                                          Content="Put images and videos in separate folders"
                                          Style="{StaticResource ProductCheckBoxStyle}"
                                          ToolTip="Creates images and videos folders inside the save location" />
                                <CheckBox x:Name="ChkStartWindows"
                                          Content="Open Parallax Capture when Windows starts"
                                          Style="{StaticResource ProductCheckBoxStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Hotkeys">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Keyboard shortcuts"
                                   Style="{StaticResource ProductSectionHeaderTextStyle}"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Use shortcuts like PrintScreen, Alt+PrintScreen, Ctrl+Shift+S, Win+F9, or None. Turn off an action to disable its shortcut."
                                   TextWrapping="Wrap"
                                   Style="{StaticResource ProductCaptionTextStyle}"
                                   Margin="0,0,0,14" />

                        <Border Style="{StaticResource ProductSectionBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="116" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           Text="Action"
                                           Style="{StaticResource ProductSectionLabelStyle}"
                                           Margin="0,0,12,8" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="1"
                                           Text="State"
                                           Style="{StaticResource ProductSectionLabelStyle}"
                                           Margin="0,0,12,8" />
                                <TextBlock Grid.Row="0"
                                           Grid.Column="2"
                                           Text="Shortcut"
                                           Style="{StaticResource ProductSectionLabelStyle}"
                                           Margin="0,0,0,8" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="Capture region"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ProductBodyTextStyle}"
                                           Margin="0,0,12,12" />
                                <CheckBox x:Name="ChkHotkeyScreenshotEnabled"
                                          Grid.Row="1"
                                          Grid.Column="1"
                                          Content="Use shortcut"
                                          Checked="HotkeyInput_Changed"
                                          Unchecked="HotkeyInput_Changed"
                                          Style="{StaticResource ProductCheckBoxStyle}"
                                          Margin="0,0,12,12" />
                                <TextBox x:Name="TxtHotkeyScreenshot"
                                         Grid.Row="1"
                                         Grid.Column="2"
                                         TextChanged="HotkeyInput_Changed"
                                         Style="{StaticResource ProductTextBoxStyle}"
                                         Margin="0,0,0,12" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Text="Capture full screen"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ProductBodyTextStyle}"
                                           Margin="0,0,12,12" />
                                <CheckBox x:Name="ChkHotkeyFullscreenEnabled"
                                          Grid.Row="2"
                                          Grid.Column="1"
                                          Content="Use shortcut"
                                          Checked="HotkeyInput_Changed"
                                          Unchecked="HotkeyInput_Changed"
                                          Style="{StaticResource ProductCheckBoxStyle}"
                                          Margin="0,0,12,12" />
                                <TextBox x:Name="TxtHotkeyFullscreen"
                                         Grid.Row="2"
                                         Grid.Column="2"
                                         TextChanged="HotkeyInput_Changed"
                                         Style="{StaticResource ProductTextBoxStyle}"
                                         Margin="0,0,0,12" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Text="Start or stop recording"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ProductBodyTextStyle}"
                                           Margin="0,0,12,0" />
                                <CheckBox x:Name="ChkHotkeyRegionVideoEnabled"
                                          Grid.Row="3"
                                          Grid.Column="1"
                                          Content="Use shortcut"
                                          Checked="HotkeyInput_Changed"
                                          Unchecked="HotkeyInput_Changed"
                                          Style="{StaticResource ProductCheckBoxStyle}"
                                          Margin="0,0,12,0" />
                                <TextBox x:Name="TxtHotkeyRegionVideo"
                                         Grid.Row="3"
                                         Grid.Column="2"
                                         TextChanged="HotkeyInput_Changed"
                                         Style="{StaticResource ProductTextBoxStyle}" />
                            </Grid>
                        </Border>

                        <TextBlock x:Name="TxtHotkeyStatus"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource ProductCaptionTextStyle}"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Text="Changes apply after you save."
                       Style="{StaticResource ProductCaptionTextStyle}"
                       VerticalAlignment="Center" />
            <Button Content="Save settings"
                    Click="BtnSave_Click"
                    IsDefault="True"
                    MinWidth="128"
                    HorizontalAlignment="Right"
                    Style="{StaticResource ProductPrimaryButtonStyle}" />
        </Grid>
    </Grid>
</Window>
